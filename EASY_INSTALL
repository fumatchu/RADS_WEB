#!/usr/bin/env bash
# =============================================================================
#  RADS_WEB Easy Installer — Rocky Active Directory Server Web Edition
#  Usage: curl -fsSL https://raw.githubusercontent.com/fumatchu/RADS_WEB/main/EASY_INSTALL | bash
# =============================================================================
set -euo pipefail

RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[1;33m'
BLU='\033[0;34m'
NC='\033[0m'

banner() {
cat << 'EOF'

     ____  _    ____  ____       _    _______ ____
    |  _ \/ \  |  _ \/ ___|_    | |  | ____| __ )
    | |_) / _ \ | | | \___ \ \  | |  |  _| |  _ \
    |  _ / ___ \| |_| |___) | | | |__| |___| |_) |
    |_| /_/   \_|____/|____/ |_||_____|_____|____/

     Rocky Active Directory Server — Web Edition
     Rocky Linux 10+ | Samba AD/DC from SRPM

EOF
}

die() { echo -e "${RED}[ERROR]${NC} $*" >&2; exit 1; }
info() { echo -e "${BLU}[INFO]${NC}  $*"; }
ok()   { echo -e "${GRN}[OK]${NC}    $*"; }
warn() { echo -e "${YLW}[WARN]${NC}  $*"; }

banner

# ── Root check ───────────────────────────────────────────────────────────────
[[ $EUID -ne 0 ]] && die "This script must be run as root."

# ── OS check ─────────────────────────────────────────────────────────────────
if [[ ! -f /etc/os-release ]]; then
    die "Cannot read /etc/os-release — is this a supported Linux distribution?"
fi
source /etc/os-release
if [[ "${ID,,}" != "rocky" ]]; then
    die "RADS_WEB requires Rocky Linux. Detected: ${PRETTY_NAME:-unknown}"
fi
OSVER_MAJOR="${VERSION_ID%%.*}"
if (( OSVER_MAJOR < 10 )); then
    die "Rocky Linux 10+ required. Detected: ${PRETTY_NAME}"
fi
ok "Rocky Linux ${VERSION_ID} detected"

# ── Install prerequisites ─────────────────────────────────────────────────────
info "Installing prerequisites..."
dnf install -y wget git ipcalc dialog &>/dev/null
ok "Prerequisites installed"

# ── Clone repository ──────────────────────────────────────────────────────────
INSTALL_DIR="/root/RADS_WEBInstaller"
if [[ -d "$INSTALL_DIR" ]]; then
    warn "Existing installation directory found at $INSTALL_DIR"
    info "Pulling latest changes..."
    git -C "$INSTALL_DIR" pull --ff-only 2>/dev/null || true
else
    info "Cloning RADS_WEB repository..."
    git clone https://github.com/fumatchu/RADS_WEB.git "$INSTALL_DIR"
fi
ok "Repository ready at $INSTALL_DIR"

# ── Launch main installer ─────────────────────────────────────────────────────
INSTALLER="$INSTALL_DIR/RADS_WEBInstall.sh"
if [[ ! -f "$INSTALLER" ]]; then
    die "Main installer not found at $INSTALLER"
fi
chmod +x "$INSTALLER"
info "Launching RADS_WEB installer..."
echo ""
exec bash "$INSTALLER"
